rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check user role
    function hasRole(roleList) {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in roleList;
    }

    // Grants: Authenticated members can read. Only admins/managers can write.
    match /grants/{grantId} {
      allow read: if request.auth != null;
      allow write: if hasRole(['admin', 'manager']);
    }

    // Activity logs: Authenticated users can read and create (for audit trail). No deletions/updates.
    match /activity/{logId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false; 
    }

    // User Profile: Users can read anyone's profile (for display), but only write their own.
    // Exception: Admins can update roles.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == userId || hasRole(['admin']));
    }

    // User tokens: users can only access their own OAuth tokens
    match /userTokens/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Settings: Only admins can manage global settings
    match /settings/{doc} {
      allow read: if request.auth != null;
      allow write: if hasRole(['admin']);
    }
  }
}
