rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Grants: any authenticated team member can read/write
    match /grants/{grantId} {
      allow read, write: if request.auth != null;
    }

    // Activity logs: authenticated users can read and create, but not modify history
    match /activity/{logId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }

    // User tokens: users can only access their own OAuth tokens
    match /userTokens/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Settings: any authenticated team member can read/write
    match /settings/{doc} {
      allow read, write: if request.auth != null;
    }
  }
}
